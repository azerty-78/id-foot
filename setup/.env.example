# Copier vers /home/deploy/id-foot/.env sur le VPS et adapter les valeurs.
# Ne jamais committer le fichier .env réel.

NODE_ENV=production

# ── PostgreSQL ───────────────────────────────────────────────────────────────
# Conteneur Docker nommé "id-foot-db" sur le réseau "id-foot-network" :
POSTGRES_USER=idfoot
POSTGRES_PASSWORD=change-me-strong-password
POSTGRES_DB=id_foot
DATABASE_URL=postgresql://idfoot:change-me-strong-password@id-foot-db:5432/id_foot?schema=public

# ── NextAuth ─────────────────────────────────────────────────────────────────
# Générer NEXTAUTH_SECRET : openssl rand -base64 32
NEXTAUTH_SECRET=change-me-to-a-long-random-secret-min-32-chars
NEXTAUTH_URL=https://id-foot.kobecorporation.com

# URL publique (build-time + runtime — doit correspondre au domaine)
NEXT_PUBLIC_APP_URL=https://id-foot.kobecorporation.com

# Port interne du conteneur Next.js (4003 = port hôte Nginx, voir deploy.yml)
PORT=3000
