generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  ADMIN
  MANAGER
  SUPER_ADMIN
}

model User {
  id            String       @id @default(uuid())
  nom           String
  email         String       @unique
  passwordHash  String
  role          UserRole     @default(ADMIN)
  active        Boolean      @default(true)
  sessionVersion Int         @default(0)
  competitionId String?
  competition   Competition? @relation(fields: [competitionId], references: [id], onDelete: Cascade)
  createdAt     DateTime     @default(now())
}

model Competition {
  id           String   @id @default(uuid())
  nom          String
  abbreviation String
  slug         String   @unique
  annee        Int
  lieu         String?
  image        String?
  fullControl  Boolean  @default(false)
  createdAt    DateTime @default(now())
  equipes      Equipe[]
  users        User[]
}

model Equipe {
  id            String      @id @default(uuid())
  nom           String
  logo          String?
  competitionId String
  competition   Competition @relation(fields: [competitionId], references: [id], onDelete: Cascade)
  joueurs       Joueur[]
}

model Joueur {
  id            String    @id @default(uuid())
  nom           String
  prenom        String
  dateNaissance DateTime?
  nationalite   String?
  sexe          String?
  telephone     String?
  numero        Int?
  poste         String?
  photo         String
  qrToken       String    @unique @default(uuid())
  equipeId      String
  equipe        Equipe    @relation(fields: [equipeId], references: [id], onDelete: Cascade)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}
